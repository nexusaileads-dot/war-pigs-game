generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ----------------------------------------------------------------------
// USER & PROFILE
// ----------------------------------------------------------------------

model User {
  id         String   @id @default(uuid())
  telegramId String   @unique
  username   String?
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  profile    Profile?
  inventory  InventoryItem[]
  runs       GameRun[]
}

model Profile {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  level       Int      @default(1)
  currentPigs Int      @default(0)
  experience  Int      @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ----------------------------------------------------------------------
// INVENTORY & SHOP SYSTEM
// ----------------------------------------------------------------------

model InventoryItem {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  itemType    String   // "WEAPON" or "CHARACTER"
  itemId      String   // Maps to Character.id or Weapon.id
  isEquipped  Boolean  @default(false)
  
  acquiredAt  DateTime @default(now())

  // Ensure a user can only own one instance of a specific item
  @@unique([userId, itemId])
}

model Character {
  id          String   @id // e.g., "grunt_bacon", "iron_tusk"
  name        String
  classType   String
  description String?
  pricePigs   Int      @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Weapon {
  id          String   @id // e.g., "oink_pistol", "sow_machinegun"
  name        String
  type        String
  damage      Int
  description String?
  pricePigs   Int      @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ----------------------------------------------------------------------
// GAMEPLAY & LEVELS
// ----------------------------------------------------------------------

model Level {
  id                String   @id @default(uuid())
  levelNumber       Int      @unique
  
  name              String
  description       String
  difficulty        Int      // 1-10
  enemyTypes        String[] // JSON array of enemy IDs
  
  waves             Int
  bossId            String?
  
  baseReward        Int
  xpReward          Int
  unlockRequirement Int      @default(0) // Player level required to unlock
  
  isBossLevel       Boolean  @default(false)
  
  createdAt         DateTime @default(now())
  
  // Required relation back to GameRun
  runs              GameRun[] 
}

model GameRun {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  levelId     String
  level       Level    @relation(fields: [levelId], references: [id])
  
  status      String   // "VICTORY", "DEFEAT", "IN_PROGRESS"
  kills       Int      @default(0)
  damageDealt Int      @default(0)
  damageTaken Int      @default(0)
  timeElapsed Int      @default(0)
  
  createdAt   DateTime @default(now())
  completedAt DateTime?
}